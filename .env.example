# ===================================================
# MAEDA — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ===================================================

# --- LLM Provider (pick one or both) ---
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Default model for each agent
MAEDA_LLM_PROVIDER=openai          # openai | anthropic
MAEDA_LLM_MODEL=gpt-4o-mini        # gpt-4o | gpt-4o-mini | claude-3-5-sonnet-20241022
MAEDA_LLM_TEMPERATURE=0.0

# --- Token / Cost Limits ---
MAEDA_MAX_TOKENS_PER_CALL=4096
MAEDA_MAX_COST_PER_SESSION=1.00    # USD; aborts if exceeded

# --- MCP Sub-System URLs ---
DATA_CLEANER_MCP_URL=http://localhost:8001
RAG_SERVER_MCP_URL=http://localhost:8002

# --- Data Sources ---
MAEDA_DEFAULT_DATA_DIR=./data/sample

# --- Logging ---
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                    # json | pretty
LOG_FILE=./logs/maeda.log          # leave blank to log to stdout only

# --- Streamlit UI ---
STREAMLIT_PORT=8501

# --- Eval ---
EVAL_ENABLED=true
EVAL_GOLDEN_SUITE=./tests/eval/test_suite.json
